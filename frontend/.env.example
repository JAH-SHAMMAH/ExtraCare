# Fairview School Portal - Frontend Environment Variables
# Copy to .env.local for development, or configure in your deployment platform.
# NOTE: NEXT_PUBLIC_* values are BAKED IN AT BUILD TIME and used by the browser.

# ──────────────────────────────────────────────────────────────────────────────
# API Configuration (REQUIRED)
# ──────────────────────────────────────────────────────────────────────────────
# Public base URL of the FastAPI backend (no trailing slash). lib/api.ts appends
# /api/v1. Must be reachable FROM THE BROWSER — never an internal docker host.
# Development: http://localhost:8000
# Production:  https://fairviewschoolng.com   (nginx routes /api/* to the API)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (canonical links, sitemap). Production: https://fairviewschoolng.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Application Settings (OPTIONAL)
# ──────────────────────────────────────────────────────────────────────────────
# Application name shown in UI
NEXT_PUBLIC_APP_NAME=Fairview School Portal

# Default locale / currency (used for number formatting)
NEXT_PUBLIC_DEFAULT_LOCALE=en-NG
NEXT_PUBLIC_DEFAULT_CURRENCY=NGN

# Enable analytics / telemetry in production (true|false)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ──────────────────────────────────────────────────────────────────────────────
# Feature Flags (OPTIONAL)
# ──────────────────────────────────────────────────────────────────────────────
# Enable beta features (true|false)
NEXT_PUBLIC_ENABLE_BETA=false
