# ExtraCare ERP — environment configuration
# Copy to `.env` and fill in for your environment.
# `app.config.Settings` validates these on startup: production boots will
# refuse to start with dev defaults (see model_validator in config.py).

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | staging | production
DEBUG=true                     # MUST be false in production

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a fresh secret per environment:   openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# Any async SQLAlchemy dialect works. Examples:
#   sqlite+aiosqlite:///./extracare.db                             (dev)
#   mysql+aiomysql://user:pw@host:3306/extracare                   (TiDB / MySQL)
#   sqlite+libsql://<db>-<org>.turso.io?authToken=...              (Turso / libSQL)
#   postgresql+asyncpg://user:pw@host:5432/extracare               (PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./extracare.db
DATABASE_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

# ── Runtime ───────────────────────────────────────────────────────────────────
# MUST be false in production — use `alembic upgrade head` instead.
AUTO_CREATE_SCHEMA=true
# Expose /api/docs + /api/redoc + /api/openapi.json.
ENABLE_API_DOCS=true

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=auto                # auto | pretty | json  (auto → json in stg/prod)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated is accepted so Render/Railway-style env vars work.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@extracare.app

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
