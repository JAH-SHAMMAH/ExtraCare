# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_BEFORE_PRODUCTION

# ── Encryption-at-rest (stored secrets: gateway API keys) ─────────────────────
# SEPARATE key from SECRET_KEY. Generate:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
#
# ⚠️  DO NOT let the PRODUCTION key sit in a .env that is synced/backed-up in the
# SAME place as the database (e.g. a OneDrive-synced folder next to the .db).
# Ciphertext + key in one synced store = no protection at all. In production put
# this in the host's real environment / secret store, on a host whose DB backups
# do NOT also carry this key. See ENCRYPTION_SERVICE_SPEC.md.
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1
# JSON map of retired version->base64key, decrypt-only during rotation. e.g. {"1":"…"}
ENCRYPTION_KEYS_OLD=
# Leave OFF until the Payment Gateways feature ships. When true in production,
# the config validator requires ENCRYPTION_KEY above.
PAYMENT_GATEWAYS_ENABLED=false

# ── App ───────────────────────────────────────────────────────────────────────
# In production set ENVIRONMENT=production — this fails boot fast if SECRET_KEY
# is unset, DEBUG=true, AUTO_CREATE_SCHEMA=true, SQLite, or no PAYSTACK key.
ENVIRONMENT=development
DOMAIN=fairviewschoolng.com
DEBUG=true
ENABLE_API_DOCS=true
# Prod: false — apply schema with `alembic upgrade head` (entrypoint.sh does this).
AUTO_CREATE_SCHEMA=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated EXACT frontend origins. With cookie auth these MUST be exact
# (never "*") because requests are credentialed.
# Prod example: ALLOWED_ORIGINS=https://portal.fairviewschoolng.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Tokens ────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Cookie authentication (httpOnly) ──────────────────────────────────────────
# OFF by default = Bearer-token auth (unchanged). To move tokens into httpOnly
# cookies, set this AND the frontend NEXT_PUBLIC_COOKIE_AUTH to true together.
COOKIE_AUTH_ENABLED=false
# MUST be true in production (https). Set false ONLY for local http dev.
COOKIE_SECURE=true
# "lax" suits a same-origin SPA; "strict" is tighter; "none" requires Secure.
COOKIE_SAMESITE=lax
# Blank = host-only cookie (recommended).
COOKIE_DOMAIN=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMITS_ENABLED=true
# Global observe-only switch (logs + counts, never 429). Handy for first rollout.
RATE_LIMIT_MONITOR_ONLY=false
# Per-bucket overrides: "bucket=limit/window[/scope][/monitor]", comma-separated.
RATE_LIMIT_OVERRIDES=

# ── Single-School (Fairview) mode ─────────────────────────────────────────────
# This deployment is a dedicated portal for ONE school. Set SINGLE_SCHOOL_MODE
# to false only if you intend to run the legacy multi-tenant platform.
SINGLE_SCHOOL_MODE=true
SCHOOL_ORG_SLUG=fairview-school
SCHOOL_NAME=Fairview School
# Only emails on this domain may authenticate (the account must also exist and
# be active — domain validation alone never provisions an account).
ALLOWED_EMAIL_DOMAIN=fairviewschoolng.com

# ── Attendance ────────────────────────────────────────────────────────────────
# School-local cutoffs used to derive daily status from check-in/out events.
SCHOOL_LATE_AFTER=08:00
SCHOOL_EARLY_DEPARTURE_BEFORE=14:00

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./extracare.db

# MySQL / TiDB (production recommended)
# DATABASE_URL=mysql+aiomysql://user:password@host:3306/extracare

# Turso (distributed SQLite — great for Africa/edge)
# DATABASE_URL=libsql://your-db.turso.io?authToken=YOUR_TOKEN

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
# Mirror of COOKIE_AUTH_ENABLED — set true so the web client uses cookie auth
# (withCredentials + CSRF header + cookie WebSocket). Keep in lockstep with the
# backend flag, or auth breaks.
NEXT_PUBLIC_COOKIE_AUTH=false

# ── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@fairviewschoolng.com

# ── Payments (Paystack) ───────────────────────────────────────────────────────
# REQUIRED in production — the config validator fails boot without a real key.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=https://portal.fairviewschoolng.com/billing/callback
