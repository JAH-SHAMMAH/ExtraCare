# ─────────────────────────────────────────────────────────────────────────────
# Fairview School Portal — PRODUCTION environment template
#   cp .env.production.example .env   (next to docker-compose.prod.yml)
# Fill every value marked [REQUIRED SECRET]. docker-compose.prod.yml fails fast
# if a required secret is missing, so production can never use a dev default.
# Never commit the filled-in .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain & URLs ────────────────────────────────────────────────────────────
DOMAIN=fairviewschoolng.com
# Public HTTPS API base — BAKED INTO THE FRONTEND AT BUILD TIME and used by the
# browser. Same-domain routing (nginx sends /api/* to the API), so this is the
# site URL, NOT an internal docker host. lib/api.ts appends /api/v1.
NEXT_PUBLIC_API_URL=https://fairviewschoolng.com

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=__REPLACE__                 # [REQUIRED SECRET] openssl rand -hex 32

# ── Database (MySQL 8 / TiDB) ────────────────────────────────────────────────
DB_NAME=fairview
DB_USER=fairview
DB_PASSWORD=__REPLACE__                # [REQUIRED SECRET]
DB_ROOT_PASSWORD=__REPLACE__           # [REQUIRED SECRET]
# Optional: point at managed TiDB/RDS instead of the bundled `db` service.
# DATABASE_URL=mysql+aiomysql://user:pass@your-tidb-host:4000/fairview

# ── Payments (Paystack — LIVE keys) ──────────────────────────────────────────
PAYSTACK_SECRET_KEY=__REPLACE__        # [REQUIRED SECRET] sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...        # safe to expose

# ── School config (defaults are correct for Fairview) ────────────────────────
SINGLE_SCHOOL_MODE=true
ALLOWED_EMAIL_DOMAIN=fairviewschoolng.com
SCHOOL_ORG_SLUG=fairview-school
SCHOOL_NAME=Fairview School
SCHOOL_LATE_AFTER=08:00
SCHOOL_EARLY_DEPARTURE_BEFORE=14:00

# ── Cache (optional) ─────────────────────────────────────────────────────────
REDIS_ENABLED=false

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/fairview
BACKUP_RETENTION_DAYS=30

# ── Email (NOT WIRED — informational) ────────────────────────────────────────
# NOTE: the app does not currently send email (no SMTP integration). These vars
# are inert until email delivery is implemented. Password resets / invites are
# NOT emailed today — admins set credentials directly. Do not rely on email.
# FROM_EMAIL=noreply@fairviewschoolng.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
